# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is listed in .gitignore.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase service-role key — NEVER expose this to the browser / VITE_ prefix
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Paystack ──────────────────────────────────────────────────────────────────
# Live secret key — keep this server-side ONLY (no VITE_ prefix)
PAYSTACK_SECRET_KEY="sk_live_..."

# ── Mobigh reseller API ───────────────────────────────────────────────────────
MOBIGH_API_KEY="your-mobigh-api-key"

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_ADMIN_CHAT_ID="your-chat-id"

# ── SMS (Arkesel) ─────────────────────────────────────────────────────────────
ARKESEL_API_KEY="your-arkesel-key"
ARKESEL_SENDER_ID="EliData"
